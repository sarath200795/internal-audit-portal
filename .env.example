# Firebase configuration
# ----------------------------------------------------------------------------
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Add a Web App to the project (</> icon) and copy its config values here.
# 3. In the console, enable:
#       Authentication -> Sign-in method -> Email/Password
#       Firestore Database -> Create database (production mode)
# 4. Copy this file to ".env" (or ".env.local") and fill in the values below.
# 5. Deploy the security rules in firestore.rules to your Firestore instance.
#
# All keys MUST be prefixed with VITE_ so Vite exposes them to the client.
# Firebase web config values are not secrets, but keep your project locked down
# with the Firestore security rules included in this repo.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
